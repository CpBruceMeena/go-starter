# Application Environment
ENV=development
LOG_LEVEL=debug

# Server Configuration
SERVER_PORT=8080
SERVER_TIMEOUT=30
SHUTDOWN_TIMEOUT=10
ENABLE_SWAGGER=true

# Feature Flags (enable only what you need)
ENABLE_DATABASE=false
ENABLE_CACHE=false
ENABLE_HTTP_CLIENT=false
ENABLE_CONSUMER=false
ENABLE_WORKER=false

# Rate Limiting
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=10

# Database Configuration (enable with ENABLE_DATABASE=true)
# For SQLite local development, use: test.db
# For PostgreSQL, use: postgresql://user:password@localhost:5432/dbname
DATABASE_DSN=test.db

# Database Monitoring - Slow query threshold (queries slower than this get logged as warnings)
DB_SLOW_QUERY_THRESHOLD=1s
# Database query timeout (queries cancel after this duration)
DB_QUERY_TIMEOUT=30s

# Database Connection Pool Settings
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h

# AWS Configuration (optional)
AWS_REGION=us-east-1
AWS_ROLE=
AWS_SECRETS_NAME=

# Cache Configuration (enable with ENABLE_CACHE=true)
CACHE_TTL=3600

# External API Configuration (enable with ENABLE_HTTP_CLIENT=true)
EXTERNAL_API_TIMEOUT=10
