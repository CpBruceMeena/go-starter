# Application Environment
ENV=development
LOG_LEVEL=debug

# Server Configuration
SERVER_PORT=8080
SERVER_TIMEOUT=30
ENABLE_SWAGGER=true

# Database Configuration (SQLite by default for local development)
# For PostgreSQL, use: postgresql://user:password@localhost:5432/dbname
DATABASE_DSN=test.db

# Database Monitoring - Slow query threshold (queries slower than this get logged as warnings)
DB_SLOW_QUERY_THRESHOLD=1s
# Database query timeout (queries cancel after this duration)
DB_QUERY_TIMEOUT=30s

# Database Connection Pool Settings
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h

# AWS Configuration (optional)
AWS_REGION=us-east-1
AWS_ROLE=
AWS_SECRETS_NAME=

# Cache Configuration
CACHE_TTL=3600

# External API Configuration
EXTERNAL_API_TIMEOUT=10
